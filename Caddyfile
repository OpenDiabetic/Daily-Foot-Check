# Foot Check Node — HTTPS with an internal (self-signed) certificate,
# so phones on your LAN can use the camera (which requires a secure context).
# Trust the cert once on each device, then add the page to your home screen.

{
	auto_https disable_redirects
}

:443 {
	tls internal
	root * /srv
	file_server
	encode gzip
	header {
		# local-first: this node serves files and nothing else
		Referrer-Policy "no-referrer"
		X-Content-Type-Options "nosniff"
	}
}
